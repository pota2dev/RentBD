generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =======================
// ENUMS (Same as before)
// =======================

enum UserRole {
  TENANT
  LANDLORD
  ADMIN
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
}

enum AuthType {
  PASSWORD
  TWO_FACTOR
  PASSKEY
  GOOGLE
  GITHUB
}

enum PropertyType {
  APARTMENT
  HOUSE
  CONDO
  STUDIO
  ROOM
}

enum PropertyStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  INACTIVE
  REJECTED
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ReportType {
  PROPERTY
  USER
  REVIEW
  OTHER
}

// =======================
// MODELS WITH UUIDs
// =======================

model User {
  userId             String             @id @default(uuid())
  supabaseAuthId     String             @unique // The UUID from Supabase Auth
  email              String             @unique
  firstName          String?
  lastName           String?
  phoneNumber        String?
  profilePicture     String?
  role               UserRole           @default(TENANT)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  isActive           Boolean            @default(true)
  isBanned           Boolean            @default(false)
  createdAt          DateTime           @default(now())
  lastLogin          DateTime?

  // Relations
  authMethods      AuthMethod[]
  tenantProfile    Tenant?
  landlordProfile  Landlord?
  adminProfile     Admin?
  sentMessages     Message[]      @relation("Sender")
  receivedMessages Message[]      @relation("Receiver")
  reports          Report[]
  notifications    Notification[]
  emailLogs        EmailLog[]
}

model AuthMethod {
  authMethodId   String   @id @default(uuid())
  userId         String
  type           AuthType
  identifier     String
  credentialData String?
  isEnabled      Boolean  @default(true)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

model Tenant {
  tenantId                 String  @id @default(uuid())
  userId                   String  @unique
  bio                      String?
  occupation               String?
  numberOfPreviousBookings Int     @default(0)
  averageRating            Float   @default(0.0)

  user            User            @relation(fields: [userId], references: [userId], onDelete: Cascade)
  bookings        Booking[]
  reviews         Review[]
  savedProperties SavedProperty[]
}

model Landlord {
  landlordId    String  @id @default(uuid())
  userId        String  @unique
  bio           String?
  businessName  String?
  taxId         String?
  totalEarnings Float   @default(0.0)
  averageRating Float   @default(0.0)

  user       User       @relation(fields: [userId], references: [userId], onDelete: Cascade)
  properties Property[]
}

model Admin {
  adminId     String  @id @default(uuid())
  userId      String  @unique
  permissions String?

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

model Property {
  propertyId    String         @id @default(uuid())
  landlordId    String
  title         String
  description   String?
  type          PropertyType
  address       String
  city          String
  state         String?
  zipCode       String?
  latitude      Float?
  longitude     Float?
  bedrooms      Int?
  bathrooms     Int?
  area          Float?
  pricePerNight Decimal
  maxGuests     Int?
  status        PropertyStatus @default(DRAFT)
  averageRating Float          @default(0.0)
  totalReviews  Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  landlord       Landlord          @relation(fields: [landlordId], references: [landlordId], onDelete: Cascade)
  amenities      PropertyAmenity[]
  images         PropertyImage[]
  rules          PropertyRule[]
  availabilities Availability[]
  bookings       Booking[]
  reviews        Review[]
  savedBy        SavedProperty[]
}

model PropertyAmenity {
  amenityId   String  @id @default(uuid())
  propertyId  String
  amenityName String
  amenityType String?

  property Property @relation(fields: [propertyId], references: [propertyId], onDelete: Cascade)
}

model PropertyImage {
  imageId      String   @id @default(uuid())
  propertyId   String
  imageUrl     String
  thumbnailUrl String?
  displayOrder Int?
  isPrimary    Boolean  @default(false)
  uploadedAt   DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [propertyId], onDelete: Cascade)
}

model PropertyRule {
  ruleId     String  @id @default(uuid())
  propertyId String
  ruleText   String
  ruleType   String?

  property Property @relation(fields: [propertyId], references: [propertyId], onDelete: Cascade)
}

model Availability {
  availabilityId String   @id @default(uuid())
  propertyId     String
  startDate      DateTime @db.Date
  endDate        DateTime @db.Date
  isAvailable    Boolean  @default(true)
  priceOverride  Decimal?

  property Property @relation(fields: [propertyId], references: [propertyId], onDelete: Cascade)
}

model Booking {
  bookingId       String        @id @default(uuid())
  propertyId      String
  tenantId        String
  checkInDate     DateTime      @db.Date
  checkOutDate    DateTime      @db.Date
  numberOfGuests  Int?
  totalPrice      Decimal
  status          BookingStatus @default(PENDING)
  specialRequests String?
  requestedAt     DateTime      @default(now())
  respondedAt     DateTime?

  property Property  @relation(fields: [propertyId], references: [propertyId])
  tenant   Tenant    @relation(fields: [tenantId], references: [tenantId])
  messages Message[]
  review   Review?
  payments Payment[]
}

model Review {
  reviewId   String   @id @default(uuid())
  propertyId String
  tenantId   String
  bookingId  String   @unique
  rating     Int
  reviewText String?
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [propertyId])
  tenant   Tenant   @relation(fields: [tenantId], references: [tenantId])
  booking  Booking  @relation(fields: [bookingId], references: [bookingId])
}

model Payment {
  paymentId       String        @id @default(uuid())
  bookingId       String
  amount          Decimal
  status          PaymentStatus @default(PENDING)
  method          String?
  transactionId   String?       @unique
  processedAt     DateTime?
  gatewayResponse String?

  booking Booking @relation(fields: [bookingId], references: [bookingId])
}

model Message {
  messageId   String   @id @default(uuid())
  senderId    String
  receiverId  String
  bookingId   String?
  messageText String
  isRead      Boolean  @default(false)
  sentAt      DateTime @default(now())

  sender   User     @relation("Sender", fields: [senderId], references: [userId])
  receiver User     @relation("Receiver", fields: [receiverId], references: [userId])
  booking  Booking? @relation(fields: [bookingId], references: [bookingId])
}

model SavedProperty {
  savedPropertyId String   @id @default(uuid())
  tenantId        String
  propertyId      String
  savedAt         DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [tenantId])
  property Property @relation(fields: [propertyId], references: [propertyId])

  @@unique([tenantId, propertyId])
}

model Report {
  reportId    String     @id @default(uuid())
  reporterId  String
  type        ReportType
  targetId    String // This is a polymorphic ID, now String to match UUIDs
  reason      String?
  description String?
  status      String     @default("PENDING")
  createdAt   DateTime   @default(now())

  reporter User @relation(fields: [reporterId], references: [userId])
}

model Notification {
  notificationId  String   @id @default(uuid())
  userId          String
  type            String
  title           String?
  message         String?
  isRead          Boolean  @default(false)
  relatedEntityId String?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [userId])
}

model EmailLog {
  emailLogId String   @id @default(uuid())
  userId     String?
  type       String
  recipient  String
  subject    String?
  body       String?
  status     String?
  sentAt     DateTime @default(now())

  user User? @relation(fields: [userId], references: [userId])
}